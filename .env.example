# Public origin, with no trailing slash. The GitHub callback is APP_ORIGIN/auth/github/callback.
APP_ORIGIN=http://localhost:3000
# SvelteKit's Node adapter uses this to validate same-origin form submissions.
# Keep it identical to APP_ORIGIN when starting the built server without npm start.
ORIGIN=http://localhost:3000

# Create an OAuth app at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Only these GitHub accounts may become administrators (case-insensitive).
GITHUB_ALLOWED_USERS=Alfagov
# Numeric GitHub IDs are safer than mutable usernames and can be used instead/in addition.
GITHUB_ALLOWED_IDS=

# Generate with: openssl rand -base64 48
SESSION_SECRET=

PORT=3000
DATA_FILE=./data/content.json
SESSION_TTL_SECONDS=28800
